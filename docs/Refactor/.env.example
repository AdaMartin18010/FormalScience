# =============================================================================
# FormalScience 项目环境变量配置文件
# 复制此文件为 .env 并根据实际情况修改
# =============================================================================

# =============================================================================
# 基础配置 (Basic Configuration)
# =============================================================================

# 应用名称
APP_NAME=FormalScience

# 运行环境: development | staging | production
NODE_ENV=development

# 应用版本 (会自动从 VERSION 文件读取)
APP_VERSION=v4.0.0

# 服务器监听端口
PORT=3000

# 主机地址 (0.0.0.0 允许所有IP访问，localhost仅本地)
HOST=0.0.0.0

# =============================================================================
# 数据库配置 (Database Configuration)
# =============================================================================

# PostgreSQL 主数据库连接URL
# 格式: postgresql://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgresql://formalscience:password@localhost:5432/formalscience

# PostgreSQL 连接池配置
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_TIMEOUT=5000

# Redis 缓存配置
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Redis 缓存过期时间 (秒)
REDIS_CACHE_TTL=3600

# =============================================================================
# 认证与安全 (Authentication & Security)
# =============================================================================

# JWT 密钥 (生产环境必须使用强随机字符串，至少32位)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# JWT 令牌过期时间
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# 密码加密盐值轮数
BCRYPT_ROUNDS=12

# CORS 允许的来源 (生产环境配置具体域名)
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# 请求体大小限制
BODY_LIMIT=10mb

# API 速率限制 (请求/分钟)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# =============================================================================
# 日志配置 (Logging Configuration)
# =============================================================================

# 日志级别: error | warn | info | debug | trace
LOG_LEVEL=info

# 日志输出方式: console | file | both
LOG_OUTPUT=console

# 日志文件路径 (当 LOG_OUTPUT 为 file 或 both 时有效)
LOG_FILE_PATH=./logs/app.log

# 是否启用结构化日志 (JSON格式)
LOG_JSON_FORMAT=false

# =============================================================================
# 邮件服务 (Email Service)
# =============================================================================

# SMTP 服务器配置
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@example.com
SMTP_PASS=your-smtp-password

# 发件人信息
EMAIL_FROM_NAME=FormalScience
EMAIL_FROM_ADDRESS=noreply@formalscience.local

# =============================================================================
# 文件存储 (File Storage)
# =============================================================================

# 存储类型: local | s3 | minio
STORAGE_TYPE=local

# 本地存储路径
STORAGE_LOCAL_PATH=./uploads

# S3/MinIO 配置
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=formalscience
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# 文件上传限制 (MB)
UPLOAD_MAX_SIZE=50

# 允许的文件类型 (逗号分隔)
UPLOAD_ALLOWED_TYPES=.jpg,.jpeg,.png,.pdf,.doc,.docx

# =============================================================================
# 外部服务集成 (External Services)
# =============================================================================

# AI 服务 API 密钥
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1

# 可选: Azure OpenAI 配置
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_KEY=your-azure-key
AZURE_OPENAI_DEPLOYMENT=gpt-4

# =============================================================================
# 消息队列 (Message Queue)
# =============================================================================

# RabbitMQ 配置
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_QUEUE_PREFIX=formalscience

# 任务队列配置
QUEUE_CONCURRENCY=5
QUEUE_RETRY_ATTEMPTS=3

# =============================================================================
# 监控与可观测性 (Monitoring & Observability)
# =============================================================================

# 是否启用性能监控
ENABLE_METRICS=true
METRICS_PORT=9090

# Prometheus 推送网关 (可选)
PROMETHEUS_PUSHGATEWAY=

# Jaeger/Zipkin 追踪配置
JAEGER_ENDPOINT=http://localhost:14268/api/traces
TRACE_SAMPLE_RATE=1.0

# Sentry 错误追踪 (生产环境推荐)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# =============================================================================
# 功能开关 (Feature Flags)
# =============================================================================

# 启用/禁用特定功能
FEATURE_AI_INTEGRATION=true
FEATURE_WEBSOCKET=true
FEATURE_FILE_UPLOAD=true
FEATURE_EMAIL_NOTIFICATION=true
FEATURE_ANALYTICS=true

# 维护模式
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=系统维护中，请稍后再试

# =============================================================================
# 开发调试配置 (Development/Debug)
# =============================================================================

# 是否启用Swagger文档
ENABLE_SWAGGER=true

# 是否启用GraphQL Playground
ENABLE_GRAPHQL_PLAYGROUND=true

# 调试模式 (显示详细错误信息)
DEBUG=true
DEBUG_MODULES=*

# 热重载 (开发环境)
HOT_RELOAD=true

# =============================================================================
# 时区与国际化 (Timezone & I18n)
# =============================================================================

# 默认时区
DEFAULT_TIMEZONE=Asia/Shanghai

# 默认语言
DEFAULT_LOCALE=zh-CN

# 支持的语音列表
SUPPORTED_LOCALES=zh-CN,en-US

# =============================================================================
# 提示与说明
# =============================================================================
# 
# 1. 永远不要将包含真实密码的 .env 文件提交到版本控制
# 2. 生产环境必须使用强密码和安全的JWT密钥
# 3. 建议使用密钥管理服务 (如 AWS Secrets Manager, Azure Key Vault)
# 4. 定期轮换密码和API密钥
# 5. 不同环境使用不同的配置文件
#
# Docker Compose 使用示例:
#   docker-compose --env-file .env up -d
#
# Kubernetes 使用示例:
#   kubectl create secret generic formalscience-config --from-env-file=.env
#
# =============================================================================
