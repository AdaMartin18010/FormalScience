# =============================================================================
# Docker Ignore File - FormalScience Project
# =============================================================================
# 排除不需要的文件，减小镜像大小和构建时间
# =============================================================================

# -----------------------------------------------------------------------------
# Git 相关
# -----------------------------------------------------------------------------
.git
.gitignore
.gitattributes
.gitmodules

# -----------------------------------------------------------------------------
# 文档和说明文件（保留必要的）
# -----------------------------------------------------------------------------
*.md
!README.md
!LICENSE
docs/_build
docs/_static/generated
**/*.pdf
**/*.docx
**/*.pptx

# -----------------------------------------------------------------------------
# IDE 和编辑器配置
# -----------------------------------------------------------------------------
# VS Code
.vscode/
.vscode-test/
*.code-workspace

# IntelliJ / JetBrains
.idea/
*.iml
*.ipr
*.iws
out/

# Vim
*.swp
*.swo
*~
.vim/

# Emacs
*~
\#*\#
.#*

# Sublime
*.sublime-project
*.sublime-workspace

# -----------------------------------------------------------------------------
# 操作系统文件
# -----------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/

# Linux
.fuse_hidden*
.directory
.Trash-*
.nfs*

# -----------------------------------------------------------------------------
# 依赖和包管理器
# -----------------------------------------------------------------------------
# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
env.bak/
venv.bak/
.env
.venv
pip-log.txt
pip-delete-this-directory.txt
*.egg-info/
dist/
build/
*.egg

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json
yarn.lock
.pnp.*

# Rust
target/
Cargo.lock
**/*.rs.bk
*.pdb

# Lean
build/
.lake/build
.lake/packages/*/
!lake-packages/mathlib/

# -----------------------------------------------------------------------------
# 测试和覆盖率
# -----------------------------------------------------------------------------
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
htmlcov/

# -----------------------------------------------------------------------------
# 日志和临时文件
# -----------------------------------------------------------------------------
*.log
logs/
log/
tmp/
temp/
*.tmp
*.temp
*.pid
*.seed
*.pid.lock

# -----------------------------------------------------------------------------
# 编译输出
# -----------------------------------------------------------------------------
*.o
*.obj
*.a
*.lib
*.dll
*.so
*.dylib
*.exe
*.out
*.app

# -----------------------------------------------------------------------------
# 备份文件
# -----------------------------------------------------------------------------
*.bak
*.backup
*.orig
*.rej
*.old
*.save

# -----------------------------------------------------------------------------
# 大数据文件
# -----------------------------------------------------------------------------
*.tar
*.tar.gz
*.tgz
*.zip
*.rar
*.7z
*.iso
*.bin

# 数据集（如果有大型数据集）
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
data/cache/*
!data/cache/.gitkeep

# 模型文件
models/*.pkl
models/*.h5
models/*.pt
models/*.pth
models/*.onnx
models/checkpoints/*
!models/checkpoints/.gitkeep

# -----------------------------------------------------------------------------
# Docker 相关
# -----------------------------------------------------------------------------
Dockerfile*
docker-compose*.yml
.docker/
.dockerignore

# -----------------------------------------------------------------------------
# CI/CD 配置
# -----------------------------------------------------------------------------
.github/
.gitlab-ci.yml
.travis.yml
.circleci/
Jenkinsfile
azure-pipelines.yml

# -----------------------------------------------------------------------------
# 其他
# -----------------------------------------------------------------------------
# 本地配置文件
*.local
.env.local
.env.*.local
config.local.yaml

# 证书和密钥（确保安全）
*.pem
*.key
*.crt
*.p12
*.pfx
secrets/
secrets.*.yaml
secrets.*.json

# 笔记和个人文件
notes/
TODO*
todo*
*.private
